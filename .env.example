# Copy to .env and fill in. .env is gitignored.

# LLM provider key for Cognee.
# Docs: https://docs.cognee.ai/setup-configuration/llm-providers
LLM_API_KEY=

# Optional overrides. Sensible defaults are baked into deja/config.py.
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# Local data root for Cognee (SQLite / LanceDB / Kuzu). Defaults to ./data/.
# DEJA_DATA_DIR=./data

# Learner identity for a single-user demo.
DEJA_LEARNER_NAME=Gajanand

# Optional — Cognee Cloud. Enables `deja ask --cloud` (routes recall to the
# hosted service instead of the local stack). Get these from
# https://platform.cognee.ai → API Keys (free tier, no card).
# COGNEE_SERVICE_URL=https://<your-tenant>.aws.cognee.ai
# COGNEE_API_KEY=
